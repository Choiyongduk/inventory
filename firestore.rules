rules_version = '2';

// 재고관리 전용 Firebase 프로젝트 보안 규칙.
// 로그인(구글)한 사용자만 읽기/쓰기 가능합니다.
service cloud.firestore {
  match /databases/{database}/documents {

    // 특정 팀원만 허용하려면 아래 allowlist 를 사용하세요.
    // function allowed() {
    //   return request.auth != null && request.auth.token.email in [
    //     'cyd8964@gmail.com'
    //     // , '팀원2@gmail.com'
    //     // , '팀원3@company.com'
    //   ];
    // }
    // match /{document=**} { allow read, write: if allowed(); }

    // 기본: 로그인한 사용자 누구나 (전용 프로젝트라 전체 잠금이 안전)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
